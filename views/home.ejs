<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>GeoTrack | Live Location Sharing</title>
    
    <!-- Leaflet Map Library (Free, No API Key Required!) -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
    
    <style>
        :root {
            --blue: #3b82f6;
            --dark: #0f172a;
            --white: #ffffff;
            --gray: #94a3b8;
            --green: #10b981;
            --red: #ef4444;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif; }

        body {
            background-color: var(--dark);
            color: var(--white);
            min-height: 100dvh;
            display: flex;
            overflow-x: hidden;
            overflow-y: auto;
            position: relative;
        }

        .bg-grid {
            position: absolute;
            width: 200%; height: 200%;
            background-image: 
                linear-gradient(rgba(59, 130, 246, 0.1) 1px, transparent 1px),
                linear-gradient(90deg, rgba(59, 130, 246, 0.1) 1px, transparent 1px);
            background-size: 40px 40px;
            transform: perspective(500px) rotateX(60deg);
            top: -50%;
            z-index: -1;
        }

        .dashboard-container {
            width: 100%;
            min-height: 100dvh;
            display: flex;
            background: var(--dark);
        }

        .sidebar {
            width: clamp(280px, 26vw, 340px);
            background: rgba(30, 41, 59, 0.98);
            border-right: 1px solid rgba(59, 130, 246, 0.2);
            padding: 20px;
            overflow-y: auto;
            display: flex;
            flex-direction: column;
            gap: 20px;
            box-shadow: 0 0 20px rgba(0, 0, 0, 0.5);
        }

        .sidebar-header {
            display: flex;
            align-items: center;
            gap: 10px;
            padding-bottom: 15px;
            border-bottom: 1px solid rgba(59, 130, 246, 0.2);
        }

        .sidebar-header .logo {
            width: 40px;
            height: 40px;
            background: linear-gradient(135deg, var(--blue), var(--green));
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 20px;
            font-weight: bold;
        }

        .sidebar-header h2 {
            font-size: 18px;
            color: var(--white);
        }

        .user-info {
            background: rgba(59, 130, 246, 0.1);
            padding: 15px;
            border-radius: 10px;
            border: 1px solid rgba(59, 130, 246, 0.2);
        }

        .user-info p {
            font-size: 12px;
            color: var(--gray);
            margin: 0 0 5px 0;
            text-transform: uppercase;
        }

        .user-name {
            font-size: 15px;
            color: var(--white);
            font-weight: 600;
            margin-bottom: 3px;
        }

        .user-email {
            font-size: 12px;
            color: var(--blue);
            margin-bottom: 10px;
        }

        .status-badge {
            display: inline-block;
            padding: 6px 12px;
            border-radius: 6px;
            font-size: 12px;
            font-weight: 600;
            background: rgba(16, 185, 129, 0.2);
            color: var(--green);
            border: 1px solid rgba(16, 185, 129, 0.3);
        }

        .status-badge.online {
            background: rgba(16, 185, 129, 0.2);
            color: var(--green);
            border-color: rgba(16, 185, 129, 0.3);
        }

        .status-badge.offline {
            background: rgba(148, 163, 184, 0.2);
            color: var(--gray);
            border-color: rgba(148, 163, 184, 0.3);
        }

        .friend-meta {
            display: flex;
            align-items: center;
            gap: 8px;
        }

        .marker-popup {
            font-family: Arial, sans-serif;
            color: #333;
            min-width: 150px;
        }

        .marker-popup h3 {
            margin: 0 0 8px 0;
            font-size: 14px;
            color: #222;
        }

        .marker-popup p {
            margin: 4px 0;
            font-size: 12px;
            color: #555;
        }

        .location-toggle {
            display: flex;
            align-items: center;
            gap: 10px;
            padding: 12px;
            background: rgba(59, 130, 246, 0.1);
            border-radius: 8px;
            border: 1px solid rgba(59, 130, 246, 0.2);
            margin: 10px 0;
        }

        .toggle-switch {
            width: 50px;
            height: 26px;
            background: rgba(239, 68, 68, 0.5);
            border-radius: 13px;
            cursor: pointer;
            position: relative;
            transition: 0.3s;
            border: 1px solid rgba(239, 68, 68, 0.3);
        }

        .toggle-switch.active {
            background: var(--green);
            border-color: var(--green);
        }

        .toggle-switch::after {
            content: '';
            position: absolute;
            width: 22px;
            height: 22px;
            background: var(--white);
            border-radius: 50%;
            top: 2px;
            left: 2px;
            transition: 0.3s;
        }

        .toggle-switch.active::after {
            left: 26px;
        }

        .toggle-label {
            font-size: 13px;
            color: var(--gray);
            flex: 1;
        }

        .friends-section {
            flex: 1;
            display: flex;
            flex-direction: column;
        }

        .friends-header {
            font-size: 12px;
            text-transform: uppercase;
            color: var(--gray);
            margin: 0 0 12px 0;
            padding-bottom: 10px;
            border-bottom: 1px solid rgba(59, 130, 246, 0.2);
            font-weight: 600;
            letter-spacing: 0.5px;
        }

        .friends-list {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 8px;
            overflow-y: auto;
        }

        .friend-item {
            padding: 12px;
            background: rgba(59, 130, 246, 0.1);
            border-radius: 10px;
            border: 1px solid rgba(59, 130, 246, 0.2);
            cursor: pointer;
            transition: 0.3s;
            display: flex;
            align-items: center;
            justify-content: space-between;
            gap: 10px;
            font-size: 14px;
        }

        .friend-item:hover {
            background: rgba(59, 130, 246, 0.2);
            border-color: rgba(59, 130, 246, 0.4);
            transform: translateX(5px);
        }

        .friend-item.active {
            background: rgba(59, 130, 246, 0.3);
            border-color: var(--blue);
            box-shadow: 0 0 10px rgba(59, 130, 246, 0.3);
        }

        .friend-info {
            display: flex;
            align-items: center;
            gap: 10px;
            flex: 1;
            min-width: 0;
        }

        .friend-avatar {
            width: 30px;
            height: 30px;
            background: linear-gradient(135deg, var(--blue), var(--green));
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 12px;
            font-weight: bold;
            flex-shrink: 0;
        }

        .friend-name {
            color: var(--gray);
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .friend-status {
            width: 8px;
            height: 8px;
            border-radius: 50%;
            flex-shrink: 0;
        }

        .friend-status.online {
            background: var(--green);
            box-shadow: 0 0 8px var(--green);
        }

        .friend-status.offline {
            background: var(--gray);
        }

        .sidebar-footer {
            display: flex;
            flex-direction: column;
            gap: 8px;
            padding-top: 15px;
            border-top: 1px solid rgba(59, 130, 246, 0.2);
        }

        .sidebar-btn {
            padding: 10px 12px;
            border-radius: 10px;
            border: 1px solid rgba(59, 130, 246, 0.3);
            background: transparent;
            color: var(--gray);
            cursor: pointer;
            font-size: 14px;
            transition: 0.2s;
            text-align: left;
        }

        .sidebar-btn:hover {
            background: rgba(59, 130, 246, 0.15);
            color: var(--white);
            border-color: rgba(59, 130, 246, 0.5);
        }

        .sidebar-btn.logout {
            color: #ef4444;
            border-color: rgba(239, 68, 68, 0.3);
        }

        .sidebar-btn.logout:hover {
            background: rgba(239, 68, 68, 0.15);
            color: #fca5a5;
            border-color: rgba(239, 68, 68, 0.5);
        }

        .main-content {
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
            min-width: 0;
        }

        .dashboard-header {
            padding: 20px 30px;
            border-bottom: 1px solid rgba(59, 130, 246, 0.2);
            background: rgba(30, 41, 59, 0.5);
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        .dashboard-header h1 {
            margin: 0;
            font-size: 28px;
        }

        .header-actions {
            display: flex;
            gap: 10px;
            align-items: center;
        }

        .header-btn {
            padding: 10px 15px;
            border-radius: 8px;
            border: none;
            background: rgba(59, 130, 246, 0.2);
            color: var(--blue);
            cursor: pointer;
            font-size: 13px;
            transition: 0.2s;
        }

        .header-btn:hover {
            background: rgba(59, 130, 246, 0.3);
        }

        .user-count {
            padding: 8px 15px;
            background: rgba(16, 185, 129, 0.1);
            border: 1px solid rgba(16, 185, 129, 0.2);
            color: var(--green);
            border-radius: 6px;
            font-size: 12px;
            font-weight: 600;
        }

        .map-area {
            flex: 1;
            padding: 20px;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow: hidden;
            position: relative;
            min-height: 0;
        }

        #map {
            width: 100%;
            height: 100%;
            border-radius: 15px;
            box-shadow: 0 0 30px rgba(0, 0, 0, 0.5);
            min-height: 420px;
        }

        .leaflet-container {
            border-radius: 15px;
        }

        .map-placeholder {
            width: 100%;
            height: 100%;
            background: linear-gradient(135deg, rgba(59, 130, 246, 0.15), rgba(16, 185, 129, 0.1));
            border: 2px dashed rgba(59, 130, 246, 0.3);
            border-radius: 15px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            gap: 15px;
            position: absolute;
            z-index: 1;
        }

        .map-placeholder::before {
            content: '';
            position: absolute;
            width: 100px;
            height: 100px;
            background: radial-gradient(circle, rgba(59, 130, 246, 0.3), transparent);
            border-radius: 50%;
            animation: pulse 3s ease-in-out infinite;
        }

        @keyframes pulse {
            0%, 100% { transform: scale(1); opacity: 1; }
            50% { transform: scale(1.3); opacity: 0.5; }
        }

        .map-placeholder-text {
            text-align: center;
            z-index: 1;
        }

        .map-placeholder-text h2 {
            font-size: 24px;
            color: var(--white);
            margin-bottom: 10px;
        }

        .map-placeholder-text p {
            color: var(--gray);
            margin: 0;
        }

        .map-loading {
            width: 100%;
            height: 100%;
            background: rgba(30, 41, 59, 0.9);
            border-radius: 15px;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            gap: 15px;
            position: absolute;
            z-index: 5;
        }

        .spinner {
            width: 40px;
            height: 40px;
            border: 4px solid rgba(59, 130, 246, 0.2);
            border-top: 4px solid var(--blue);
            border-radius: 50%;
            animation: spin 1s linear infinite;
        }

        @keyframes spin {
            to { transform: rotate(360deg); }
        }

        .alert {
            position: fixed;
            top: 20px;
            right: 20px;
            padding: 15px 20px;
            border-radius: 10px;
            font-size: 14px;
            display: none;
            animation: slideIn 0.3s ease;
            z-index: 1000;
            max-width: 400px;
        }

        @keyframes slideIn {
            from { opacity: 0; transform: translateX(20px); }
            to { opacity: 1; transform: translateX(0); }
        }

        .alert-success {
            background: rgba(16, 185, 129, 0.2);
            border: 1px solid rgba(16, 185, 129, 0.3);
            color: #86efac;
        }

        .alert-error {
            background: rgba(239, 68, 68, 0.2);
            border: 1px solid rgba(239, 68, 68, 0.3);
            color: #fca5a5;
        }

        .alert-info {
            background: rgba(59, 130, 246, 0.2);
            border: 1px solid rgba(59, 130, 246, 0.3);
            color: #bfdbfe;
        }

        .location-status {
            display: flex;
            flex-direction: column;
            gap: 10px;
            padding: 12px;
            background: rgba(59, 130, 246, 0.1);
            border-radius: 8px;
            border: 1px solid rgba(59, 130, 246, 0.2);
            margin: 10px 0;
        }

        .location-status.error {
            background: rgba(239, 68, 68, 0.1);
            border-color: rgba(239, 68, 68, 0.3);
        }

        .location-status.success {
            background: rgba(16, 185, 129, 0.1);
            border-color: rgba(16, 185, 129, 0.3);
        }

        .location-status-text {
            font-size: 12px;
            color: var(--gray);
            margin: 0;
        }

        .location-status.error .location-status-text {
            color: #fca5a5;
        }

        .location-status.success .location-status-text {
            color: #86efac;
        }

        .enable-location-btn {
            padding: 10px 12px;
            border-radius: 8px;
            border: 1px solid rgba(59, 130, 246, 0.5);
            background: rgba(59, 130, 246, 0.2);
            color: var(--blue);
            cursor: pointer;
            font-size: 13px;
            transition: 0.2s;
            font-weight: 600;
            text-align: center;
        }

        .enable-location-btn:hover {
            background: rgba(59, 130, 246, 0.3);
            border-color: var(--blue);
        }

        .enable-location-btn:active {
            transform: scale(0.98);
        }

        .location-instructions {
            display: none;
            background: rgba(59, 130, 246, 0.05);
            border: 1px solid rgba(59, 130, 246, 0.2);
            border-radius: 6px;
            padding: 10px;
            margin-top: 10px;
            font-size: 11px;
            color: var(--gray);
            line-height: 1.5;
        }

        .location-instructions.show {
            display: block;
        }

        /* ===== ROOM SHARE LINK SECTION ===== */
        .room-share-section {
            background: rgba(59, 130, 246, 0.08);
            border: 1px solid rgba(59, 130, 246, 0.18);
            border-radius: 14px;
            padding: 14px;
            margin: 16px 0;
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .room-share-label {
            color: var(--gray);
            font-size: 12px;
            margin: 0;
        }

        .room-share-row {
            display: flex;
            gap: 8px;
            width: 100%;
        }

        .room-share-input {
            flex: 1;
            padding: 10px 12px;
            border-radius: 10px;
            border: 1px solid rgba(59, 130, 246, 0.3);
            background: rgba(15, 23, 42, 0.9);
            color: var(--white);
            font-size: 13px;
            outline: none;
        }

        .room-share-copy-btn {
            padding: 10px 14px;
            border-radius: 10px;
            border: 1px solid rgba(59, 130, 246, 0.4);
            background: linear-gradient(135deg, var(--blue), #2563eb);
            color: var(--white);
            cursor: pointer;
            font-size: 13px;
            font-weight: 600;
            transition: all 0.2s ease;
            white-space: nowrap;
        }

        .room-share-copy-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 6px 16px rgba(59, 130, 246, 0.25);
        }

        .room-share-copy-btn:active {
            transform: translateY(0);
        }

        .room-share-anchor {
            display: block;
            color: var(--blue);
            font-size: 13px;
            text-decoration: none;
            word-break: break-all;
            background: rgba(59, 130, 246, 0.08);
            border: 1px solid rgba(59, 130, 246, 0.18);
            padding: 10px 12px;
            border-radius: 10px;
            transition: background 0.2s ease, border-color 0.2s ease;
        }

        .room-share-anchor:hover {
            background: rgba(59, 130, 246, 0.15);
            border-color: rgba(59, 130, 246, 0.35);
        }

        .group-members-section {
            background: rgba(59, 130, 246, 0.08);
            border: 1px solid rgba(59, 130, 246, 0.18);
            border-radius: 14px;
            padding: 14px;
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin-bottom: 16px;
        }

        .group-members-header {
            margin: 0;
            color: var(--gray);
            font-size: 12px;
            font-weight: 600;
            text-transform: uppercase;
        }

        .group-members-list {
            display: flex;
            flex-direction: column;
            gap: 10px;
            max-height: 180px;
            overflow-y: auto;
        }

        .room-member-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            gap: 10px;
            padding: 10px 12px;
            border-radius: 10px;
            background: rgba(15, 23, 42, 0.95);
            border: 1px solid rgba(59, 130, 246, 0.12);
        }

        .room-member-name {
            color: var(--white);
            font-size: 13px;
            flex: 1;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }

        .room-member-status {
            font-size: 12px;
            padding: 4px 8px;
            border-radius: 999px;
            color: var(--white);
            min-width: 70px;
            text-align: center;
        }

        .room-member-status.online {
            background: rgba(16, 185, 129, 0.2);
            color: var(--green);
            border: 1px solid rgba(16, 185, 129, 0.3);
        }

        .room-member-status.offline {
            background: rgba(148, 163, 184, 0.15);
            color: var(--gray);
            border: 1px solid rgba(148, 163, 184, 0.2);
        }

        .empty-room-members {
            color: var(--gray);
            font-size: 13px;
            margin: 0;
            text-align: center;
        }

        .location-instructions ol {
            margin: 5px 0;
            padding-left: 15px;
        }

        .location-instructions li {
            margin: 3px 0;
        }

        /* ===== LOCATION PERMISSION POPUP STYLES ===== */
        .location-permission-popup {
            position: fixed;
            top: 20px;
            left: 20px;
            max-width: 380px;
            background: linear-gradient(135deg, rgba(30, 41, 59, 0.98), rgba(15, 23, 42, 0.98));
            border: 1px solid rgba(59, 130, 246, 0.3);
            border-radius: 15px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5), 0 0 20px rgba(59, 130, 246, 0.2);
            padding: 0;
            z-index: 1001;
            opacity: 0;
            transform: translateX(-400px);
            transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
            pointer-events: none;
            animation: none;
        }

        .location-permission-popup.show {
            opacity: 1;
            transform: translateX(0);
            pointer-events: all;
            animation: popupSlideIn 0.5s ease-out;
        }

        @keyframes popupSlideIn {
            0% {
                opacity: 0;
                transform: translateX(-400px) scale(0.95);
            }
            60% {
                opacity: 1;
                transform: translateX(10px) scale(1.02);
            }
            100% {
                opacity: 1;
                transform: translateX(0) scale(1);
            }
        }

        .permission-popup-content {
            display: flex;
            flex-direction: column;
            gap: 16px;
            padding: 24px;
        }

        .permission-popup-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 8px;
        }

        .permission-icon {
            font-size: 28px;
            display: flex;
            align-items: center;
            justify-content: center;
            width: 40px;
            height: 40px;
            background: rgba(59, 130, 246, 0.2);
            border-radius: 10px;
        }

        .permission-popup-header h2 {
            font-size: 18px;
            font-weight: 700;
            color: var(--white);
            margin: 0;
            letter-spacing: -0.5px;
        }

        .permission-popup-message {
            display: flex;
            flex-direction: column;
            gap: 12px;
            margin: 8px 0;
        }

        .permission-popup-message p {
            font-size: 14px;
            color: var(--gray);
            line-height: 1.5;
            margin: 0;
        }

        .permission-benefits {
            font-size: 13px !important;
            color: rgba(148, 163, 184, 0.8) !important;
            font-style: italic;
            margin-top: 4px !important;
        }

        .permission-popup-actions {
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin-top: 12px;
        }

        .btn-allow-location,
        .btn-deny-location {
            padding: 12px 16px;
            border: none;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            outline: none;
        }

        .btn-icon {
            font-size: 16px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .btn-allow-location {
            background: linear-gradient(135deg, var(--blue), #2563eb);
            color: var(--white);
            border: 1px solid rgba(59, 130, 246, 0.5);
            box-shadow: 0 4px 15px rgba(59, 130, 246, 0.3);
        }

        .btn-allow-location:hover {
            background: linear-gradient(135deg, #2563eb, #1d4ed8);
            box-shadow: 0 6px 20px rgba(59, 130, 246, 0.4);
            transform: translateY(-2px);
        }

        .btn-allow-location:active {
            transform: translateY(0);
            box-shadow: 0 2px 10px rgba(59, 130, 246, 0.3);
        }

        .btn-deny-location {
            background: transparent;
            color: var(--gray);
            border: 1px solid rgba(59, 130, 246, 0.2);
        }

        .btn-deny-location:hover {
            background: rgba(59, 130, 246, 0.1);
            color: var(--white);
            border-color: rgba(59, 130, 246, 0.3);
        }

        .btn-deny-location:active {
            background: rgba(59, 130, 246, 0.15);
        }

        /* ===== LOCATION ERROR NOTIFICATION STYLES ===== */
        .location-error-notification {
            position: fixed;
            top: 20px;
            left: 20px;
            max-width: 380px;
            background: linear-gradient(135deg, rgba(127, 29, 29, 0.2), rgba(97, 22, 22, 0.2));
            border: 1px solid rgba(239, 68, 68, 0.3);
            border-radius: 12px;
            padding: 16px;
            z-index: 1000;
            opacity: 0;
            transform: translateX(-400px) scale(0.95);
            transition: all 0.3s ease;
            pointer-events: none;
            box-shadow: 0 4px 20px rgba(239, 68, 68, 0.15);
        }

        .location-error-notification.show {
            opacity: 1;
            transform: translateX(0) scale(1);
            pointer-events: all;
            animation: errorSlideIn 0.4s ease-out;
        }

        @keyframes errorSlideIn {
            0% {
                opacity: 0;
                transform: translateX(-400px) scale(0.9);
            }
            100% {
                opacity: 1;
                transform: translateX(0) scale(1);
            }
        }

        .error-content {
            display: flex;
            align-items: flex-start;
            gap: 12px;
        }

        .error-icon {
            font-size: 20px;
            flex-shrink: 0;
            margin-top: 2px;
        }

        .error-message {
            flex: 1;
            display: flex;
            flex-direction: column;
            gap: 8px;
        }

        .error-message p {
            font-size: 14px;
            color: #fca5a5;
            margin: 0;
            line-height: 1.4;
        }

        .error-action {
            font-size: 13px;
            color: #fb7185;
            text-decoration: none;
            font-weight: 600;
            cursor: pointer;
            transition: color 0.2s ease;
            align-self: flex-start;
        }

        .error-action:hover {
            color: #fda4af;
            text-decoration: underline;
        }

        .error-close {
            background: none;
            border: none;
            color: var(--gray);
            font-size: 18px;
            cursor: pointer;
            padding: 4px;
            margin-left: 8px;
            flex-shrink: 0;
            transition: color 0.2s ease;
        }

        .error-close:hover {
            color: var(--white);
        }

        /* ===== INVITE FRIENDS SHARE POPUP STYLES ===== */
        .invite-friends-popup {
            position: fixed;
            top: 50%;
            left: 50%;
            transform: translate(-50%, -50%) scale(0.9);
            background: linear-gradient(135deg, rgba(30, 41, 59, 0.98), rgba(15, 23, 42, 0.98));
            border: 1px solid rgba(59, 130, 246, 0.3);
            border-radius: 20px;
            box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5), 0 0 30px rgba(59, 130, 246, 0.2);
            padding: 0;
            z-index: 1003;
            opacity: 0;
            pointer-events: none;
            transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
            max-width: 320px;
            width: 90vw;
        }

        .invite-friends-popup.show {
            opacity: 1;
            transform: translate(-50%, -50%) scale(1);
            pointer-events: all;
        }

        .invite-friends-content {
            display: flex;
            flex-direction: column;
            gap: 20px;
            padding: 24px;
        }

        .invite-friends-header {
            display: flex;
            align-items: center;
            gap: 12px;
            justify-content: center;
            margin-bottom: 8px;
        }

        .invite-friends-icon {
            font-size: 28px;
            display: flex;
            align-items: center;
            justify-content: center;
            width: 40px;
            height: 40px;
            background: rgba(59, 130, 246, 0.2);
            border-radius: 12px;
        }

        .invite-friends-header h2 {
            font-size: 18px;
            font-weight: 700;
            color: var(--white);
            margin: 0;
            letter-spacing: -0.5px;
        }

        .invite-friends-options {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }

        .share-option-btn {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 14px 16px;
            border: none;
            border-radius: 12px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.2s ease;
            text-align: left;
            background: rgba(59, 130, 246, 0.1);
            color: var(--white);
            border: 1px solid rgba(59, 130, 246, 0.2);
        }

        .share-option-btn:hover {
            background: rgba(59, 130, 246, 0.2);
            border-color: rgba(59, 130, 246, 0.4);
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(59, 130, 246, 0.15);
        }

        .share-option-btn:active {
            transform: translateY(0);
        }

        .share-icon {
            font-size: 18px;
            flex-shrink: 0;
        }

        .whatsapp-btn:hover {
            background: rgba(37, 211, 102, 0.2);
            border-color: rgba(37, 211, 102, 0.4);
            box-shadow: 0 8px 25px rgba(37, 211, 102, 0.15);
        }

        .telegram-btn:hover {
            background: rgba(0, 136, 204, 0.2);
            border-color: rgba(0, 136, 204, 0.4);
            box-shadow: 0 8px 25px rgba(0, 136, 204, 0.15);
        }

        .copy-btn:hover {
            background: rgba(59, 130, 246, 0.2);
            border-color: rgba(59, 130, 246, 0.4);
            box-shadow: 0 8px 25px rgba(59, 130, 246, 0.15);
        }

        /* ===== ISOLATED LOCATION PERMISSION POPUP STYLES ===== */
        .isolated-location-permission-popup {
            position: fixed;
            top: 20px;
            left: 20px;
            max-width: 380px;
            background: linear-gradient(135deg, rgba(30, 41, 59, 0.98), rgba(15, 23, 42, 0.98));
            border: 1px solid rgba(59, 130, 246, 0.3);
            border-radius: 15px;
            box-shadow: 0 10px 40px rgba(0, 0, 0, 0.5), 0 0 20px rgba(59, 130, 246, 0.2);
            padding: 0;
            z-index: 1002;
            opacity: 0;
            transform: translateX(-400px);
            transition: all 0.4s cubic-bezier(0.34, 1.56, 0.64, 1);
            pointer-events: none;
        }

        .isolated-location-permission-popup.show {
            opacity: 1;
            transform: translateX(0);
            pointer-events: all;
            animation: isolatedPopupSlideIn 0.5s ease-out;
        }

        @keyframes isolatedPopupSlideIn {
            0% {
                opacity: 0;
                transform: translateX(-400px) scale(0.95);
            }
            60% {
                opacity: 1;
                transform: translateX(10px) scale(1.02);
            }
            100% {
                opacity: 1;
                transform: translateX(0) scale(1);
            }
        }

        .isolated-permission-popup-content {
            display: flex;
            flex-direction: column;
            gap: 16px;
            padding: 24px;
        }

        .isolated-permission-popup-header {
            display: flex;
            align-items: center;
            gap: 12px;
            margin-bottom: 8px;
        }

        .isolated-permission-icon {
            font-size: 28px;
            display: flex;
            align-items: center;
            justify-content: center;
            width: 40px;
            height: 40px;
            background: rgba(59, 130, 246, 0.2);
            border-radius: 10px;
        }

        .isolated-permission-popup-header h2 {
            font-size: 18px;
            font-weight: 700;
            color: var(--white);
            margin: 0;
            letter-spacing: -0.5px;
        }

        .isolated-permission-popup-message {
            display: flex;
            flex-direction: column;
            gap: 12px;
            margin: 8px 0;
        }

        .isolated-permission-popup-message p {
            font-size: 14px;
            color: var(--gray);
            line-height: 1.5;
            margin: 0;
        }

        .isolated-permission-benefits {
            font-size: 13px !important;
            color: rgba(148, 163, 184, 0.8) !important;
            font-style: italic;
            margin-top: 4px !important;
        }

        .isolated-permission-popup-actions {
            display: flex;
            flex-direction: column;
            gap: 10px;
            margin-top: 12px;
        }

        .isolated-btn-allow-location,
        .isolated-btn-deny-location {
            padding: 12px 16px;
            border: none;
            border-radius: 10px;
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
            outline: none;
        }

        .isolated-btn-icon {
            font-size: 16px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .isolated-btn-allow-location {
            background: linear-gradient(135deg, var(--blue), #2563eb);
            color: var(--white);
            border: 1px solid rgba(59, 130, 246, 0.5);
            box-shadow: 0 4px 15px rgba(59, 130, 246, 0.3);
        }

        .isolated-btn-allow-location:hover {
            background: linear-gradient(135deg, #2563eb, #1d4ed8);
            box-shadow: 0 6px 20px rgba(59, 130, 246, 0.4);
            transform: translateY(-2px);
        }

        .isolated-btn-allow-location:active {
            transform: translateY(0);
            box-shadow: 0 2px 10px rgba(59, 130, 246, 0.3);
        }

        .isolated-btn-deny-location {
            background: transparent;
            color: var(--gray);
            border: 1px solid rgba(59, 130, 246, 0.2);
        }

        .isolated-btn-deny-location:hover {
            background: rgba(59, 130, 246, 0.1);
            color: var(--white);
            border-color: rgba(59, 130, 246, 0.3);
        }

        .isolated-btn-deny-location:active {
            background: rgba(59, 130, 246, 0.15);
        }

        /* ===== HIDDEN CLASS ===== */
        .hidden {
            display: none !important;
        }

        .sidebar::-webkit-scrollbar,
        .friends-list::-webkit-scrollbar {
            width: 6px;
        }

        .sidebar::-webkit-scrollbar-track,
        .friends-list::-webkit-scrollbar-track {
            background: rgba(59, 130, 246, 0.05);
        }

        .sidebar::-webkit-scrollbar-thumb,
        .friends-list::-webkit-scrollbar-thumb {
            background: rgba(59, 130, 246, 0.3);
            border-radius: 3px;
        }

        .sidebar::-webkit-scrollbar-thumb:hover,
        .friends-list::-webkit-scrollbar-thumb:hover {
            background: rgba(59, 130, 246, 0.5);
        }

        @media (max-width: 1024px) {
            .dashboard-header h1 {
                font-size: 24px;
            }

            .sidebar {
                width: 300px;
            }

            .header-actions {
                flex-wrap: wrap;
            }

            .map-area {
                padding: 16px;
            }
        }

        @media (max-width: 768px) {
            body {
                overflow-y: auto;
            }

            .dashboard-container {
                flex-direction: column;
                min-height: 100dvh;
            }

            .sidebar {
                width: 100%;
                max-height: none;
                border-right: none;
                border-bottom: 1px solid rgba(59, 130, 246, 0.2);
                flex-direction: row;
                flex-wrap: wrap;
                padding: 15px;
                gap: 10px;
            }

            .sidebar-header,
            .user-info,
            .location-toggle,
            .room-share-section,
            .group-members-section,
            .friends-section,
            .sidebar-footer {
                width: 100%;
                flex-basis: 100%;
            }

            .friends-section {
                max-height: 150px;
            }

            .sidebar-footer {
                flex-direction: row;
                width: 100%;
                flex-basis: 100%;
            }

            .sidebar-btn {
                flex: 1;
                padding: 8px;
                font-size: 12px;
            }

            .room-share-row {
                flex-direction: column;
            }

            .room-share-copy-btn {
                width: 100%;
            }

            .dashboard-header {
                flex-direction: column;
                gap: 10px;
                align-items: flex-start;
                padding: 15px;
            }

            .dashboard-header h1 {
                font-size: 22px;
            }

            .header-actions {
                width: 100%;
                flex-wrap: wrap;
            }

            .map-area {
                padding: 15px;
                min-height: calc(100dvh - 360px);
            }

            #map {
                min-height: 360px;
            }

            .alert {
                width: calc(100% - 20px);
                right: 10px;
                left: 10px;
                max-width: none;
            }

            .location-permission-popup,
            .location-error-notification,
            .invite-friends-popup,
            .isolated-location-permission-popup {
                top: 10px;
                left: 10px;
                right: 10px;
                max-width: none;
                width: auto;
            }

            .permission-popup-content,
            .invite-friends-content,
            .isolated-permission-popup-content {
                padding: 20px;
            }

            .permission-popup-header h2,
            .invite-friends-header h2,
            .isolated-permission-popup-header h2 {
                font-size: 16px;
            }

            .permission-popup-message p,
            .isolated-permission-popup-message p {
                font-size: 13px;
            }

            .permission-benefits,
            .isolated-permission-benefits {
                font-size: 12px !important;
            }

            .btn-allow-location,
            .btn-deny-location,
            .isolated-btn-allow-location,
            .isolated-btn-deny-location {
                padding: 10px 12px;
                font-size: 13px;
            }

            .error-content {
                flex-direction: column;
                gap: 10px;
            }

            .error-message {
                flex-direction: column;
                gap: 8px;
            }

            .error-message p {
                font-size: 12px;
            }

            .error-close {
                margin-left: 0;
                align-self: flex-end;
            }
        }

        @media (max-width: 480px) {
            .sidebar {
                padding: 12px;
                gap: 8px;
            }

            .friend-item {
                width: 100%;
                justify-content: center;
                gap: 6px;
                flex-direction: column;
            }

            .dashboard-header h1 {
                font-size: 20px;
            }

            .header-btn,
            .sidebar-btn {
                width: 100%;
            }

            .map-area {
                min-height: calc(100dvh - 340px);
            }

            .settings-content {
                padding: 15px;
            }

            .settings-group {
                padding: 12px;
            }
        }
    </style>
</head>
<body data-user-id="<%= user._id %>">
    <div class="bg-grid"></div>

    <div id="alertSuccess" class="alert alert-success"></div>
    <div id="alertError" class="alert alert-error"></div>
    <div id="alertInfo" class="alert alert-info"></div>

    <div class="dashboard-container">
        <!-- SIDEBAR - USERS LIST -->
        <div class="sidebar">
            <div class="sidebar-header">
                <div class="logo">🗺️</div>
                <h2>GeoTrack</h2>
            </div>

            <div class="user-info">
                <p>Current User</p>
                <div class="user-name" id="userFullName"><%= user.fullName %></div>
                <div class="user-email" id="userEmail"><%= user.email %></div>
                <div id="location-status" class="location-status"></div>
            </div>

            <div class="location-toggle">
                <div class="toggle-label">📍 Share Location</div>
                <div class="toggle-switch" id="location-sharing-toggle-ui"></div>
            </div>

            <div class="room-share-section">
                <p class="room-share-label">Share this room</p>
                <div class="room-share-row">
                    <input id="roomShareLink" class="room-share-input" type="text" readonly aria-label="Room share link" />
                    <button id="copyRoomLinkBtn" class="room-share-copy-btn" type="button">Copy</button>
                </div>
                <a id="roomShareAnchor" class="room-share-anchor" href="#" target="_blank" rel="noopener noreferrer">Open room link</a>
            </div>

            <div class="group-members-section">
                <p class="group-members-header" id="groupMembersHeader">Group Members (0)</p>
                <div class="group-members-list" id="roomMembersList">
                    <p class="empty-room-members">No members in this room yet.</p>
                </div>
            </div>

            <button id="inviteFriendsBtn" class="sidebar-btn" style="width: 100%; margin-bottom: 8px;">👥 Invite Friends</button>

            <div style="display: flex; gap: 8px; flex-wrap: wrap;">
                <button id="refresh-users-btn" class="sidebar-btn" style="flex: 1;">🔄 Refresh</button>
                <button id="center-map-btn" class="sidebar-btn" style="flex: 1;">📍 Center</button>
                <label class="sidebar-btn" style="flex: 1; display: flex; align-items: center; gap: 5px; margin: 0;">
                    <input type="checkbox" id="auto-follow-toggle" style="width: auto;">
                    Auto-Follow
                </label>
            </div>

            <input type="checkbox" id="location-sharing-toggle" style="display: none;">

            <div class="friends-section">
                <p class="friends-header" id="usersCountHeader">Active Users (0)</p>
                <div class="friends-list" id="friends-list">
                    <p style="color: var(--gray); text-align: center; margin-top: 20px;">Loading users...</p>
                </div>
            </div>

            <div class="sidebar-footer">
                <button class="sidebar-btn" onclick="openInviteFriendsPopup()">👥 Invite Friends</button>
                <button class="sidebar-btn" onclick="openSettings()">⚙️ Settings</button>
                <button class="sidebar-btn logout" onclick="handleLogout()">🚪 Logout</button>
            </div>
        </div>

        <!-- MAIN CONTENT - MAP -->
        <div class="main-content">
            <div class="dashboard-header">
                <h1>📍 User Directory with Status</h1>
                <div class="header-actions">
                    <div class="user-count" id="onlineCount">Online: 0</div>
                </div>
            </div>

            <div class="map-area">
                <div id="map"></div>
                
                <!-- LOCATION PERMISSION POPUP -->
                <div id="locationPermissionPopup" class="location-permission-popup">
                    <div class="permission-popup-content">
                        <div class="permission-popup-header">
                            <span class="permission-icon">📍</span>
                            <h2>Enable Location</h2>
                        </div>
                        
                        <div class="permission-popup-message">
                            <p>Share your location to see nearby users on the map and appear for others.</p>
                            <p class="permission-benefits">✨ See real-time locations • 🗺️ Auto-fit map • 🟢 Show your status</p>
                        </div>
                        
                        <div class="permission-popup-actions">
                            <button id="allowLocationBtn" class="btn-allow-location">
                                <span class="btn-icon">✓</span>
                                Allow Location
                            </button>
                            <button id="denyLocationBtn" class="btn-deny-location">
                                Not Now
                            </button>
                        </div>
                    </div>
                </div>

                <!-- LOCATION ERROR NOTIFICATION -->
                <div id="locationErrorNotification" class="location-error-notification">
                    <div class="error-content">
                        <span class="error-icon">⚠️</span>
                        <div class="error-message">
                            <p id="errorMessageText">Location permission denied</p>
                            <a href="#" id="enableInSettingsLink" class="error-action">Enable in Settings →</a>
                        </div>
                        <button id="closeErrorBtn" class="error-close">✕</button>
                    </div>
                </div>

                <!-- NEW ISOLATED LOCATION PERMISSION POPUP -->
                <div id="isolatedLocationPermissionPopup" class="isolated-location-permission-popup">
                    <div class="isolated-permission-popup-content">
                        <div class="isolated-permission-popup-header">
                            <span class="isolated-permission-icon">📍</span>
                            <h2>Enable Location Access</h2>
                        </div>
                        
                        <div class="isolated-permission-popup-message">
                            <p>To see nearby users on the map and share your location with others, please allow location access.</p>
                            <p class="isolated-permission-benefits">• View real-time user locations • Auto-center map • Show online status</p>
                        </div>
                        
                        <div class="isolated-permission-popup-actions">
                            <button id="isolatedAllowLocationBtn" class="isolated-btn-allow-location">
                                <span class="isolated-btn-icon">✓</span>
                                Allow Location
                            </button>
                            <button id="isolatedDenyLocationBtn" class="isolated-btn-deny-location">
                                Cancel
                            </button>
                        </div>
                    </div>
                </div>

                <!-- INVITE FRIENDS SHARE POPUP -->
                <div id="inviteFriendsPopup" class="invite-friends-popup">
                    <div class="invite-friends-content">
                        <div class="invite-friends-header">
                            <span class="invite-friends-icon">👥</span>
                            <h2>Invite Friends</h2>
                        </div>
                        
                        <div class="invite-friends-options">
                            <button id="shareWhatsAppBtn" class="share-option-btn whatsapp-btn">
                                <span class="share-icon">💬</span>
                                WhatsApp
                            </button>
                            <button id="shareTelegramBtn" class="share-option-btn telegram-btn">
                                <span class="share-icon">✈️</span>
                                Telegram
                            </button>
                            <button id="copyLinkBtn" class="share-option-btn copy-btn">
                                <span class="share-icon">🔗</span>
                                Copy Link
                            </button>
                        </div>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <!-- Leaflet Map -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.css" />
    <script src="https://cdnjs.cloudflare.com/ajax/libs/leaflet/1.9.4/leaflet.min.js"></script>
    
    <!-- Socket.IO -->
    <script src="/socket.io/socket.io.js"></script>
    
    <!-- Enhanced Location Sharing Script -->
    <script src="/js/script.js"></script>
    <script src="/js/location-permission-popup.js"></script>

    <!-- Settings Modal -->
    <script>
        function openSettings() {
            alert('⚙️ Settings page coming soon!');
        }
    </script>
</body>
</html>
